<?xml version="1.0" encoding="utf-8"?>

<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/banner2_v2">

    <!-- Overlay semi-transparente -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"/>

    <!-- Seus outros componentes ficam aqui -->

    <!--  Logo  -->
<ImageView android:id="@+id/logo" android:layout_width="200dp" android:layout_height="80dp" android:layout_alignParentTop="true" android:layout_centerHorizontal="true" android:layout_marginTop="60dp" android:src="@drawable/print" android:contentDescription="Logo Yamamoto RPG"/>
    <!--  Card de Login  -->
<androidx.cardview.widget.CardView android:layout_width="match_parent"           android:alpha="0.8"       android:layout_height="wrap_content" android:layout_centerInParent="true" android:layout_marginLeft="30dp" android:layout_marginRight="30dp"  app:cardCornerRadius="20dp"              app:cardElevation="8dp"                android:background="#E8E8E8">
<LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="30dp" android:background="#E8E8E8">
    <!--  Título Login  -->
    <!--  Label E-mail  -->
    <TextView
        android:layout_width="wrap_content"
        android:fontFamily="@font/atista"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginBottom="30dp"
        android:text="Login"
        android:textColor="#FF7B6B"
        android:textSize="32sp"
        android:textStyle="bold" />

    <TextView android:layout_width="wrap_content" android:fontFamily="@font/robotoregular" android:layout_height="wrap_content" android:text="E-mail" android:textSize="14sp" android:textColor="@color/yamamoto_bold" android:textStyle="bold" android:layout_marginBottom="8dp"/>
    <!--  Campo E-mail  -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="12dp" android:layout_marginBottom="20dp">
        <ImageView android:layout_width="20dp" android:alpha="0.5" android:layout_height="20dp" android:src="@drawable/ic_email" android:layout_marginRight="10dp" android:contentDescription="Email icon"/>
        <EditText android:id="@+id/emailInput" android:fontFamily="@font/robotoregular"     android:alpha="0.5" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Digite seu E-mail" android:textSize="14sp" android:textColorHint="#999999" android:background="@android:color/transparent" android:inputType="textEmailAddress"/>
    </LinearLayout>
    <!--  Label Senha  -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Senha" android:textSize="14sp" android:textColor="@color/yamamoto_bold"  android:textStyle="bold" android:fontFamily="@font/robotoregular" android:layout_marginBottom="8dp"/>
    <!--  Campo Senha  -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal"  android:padding="12dp" android:layout_marginBottom="8dp">
        <ImageView android:layout_width="20dp" android:alpha="0.5" android:layout_height="20dp" android:src="@drawable/ic_lock" android:layout_marginRight="10dp" android:contentDescription="Lock icon"/>
        <EditText android:id="@+id/passwordInput" android:fontFamily="@font/robotoregular" android:alpha="0.5" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Digite sua senha" android:textSize="14sp" android:textColorHint="#999999" android:background="@android:color/transparent" android:inputType="textPassword"/>
    </LinearLayout>
    <!--  Link Esqueceu a senha  -->
    <TextView android:id="@+id/forgotPassword" android:fontFamily="@font/robotoregular" android:alpha="0.7" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Esqueceu a senha?" android:textSize="12sp" android:textColor="#666666" android:layout_gravity="end" android:layout_marginBottom="30dp" android:clickable="true" android:focusable="true"/>
    <!--  Botão Entrar  -->
    <androidx.cardview.widget.CardView android:id="@+id/btnLogin" android:layout_width="match_parent" android:layout_height="wrap_content" app:cardCornerRadius="25dp" app:cardElevation="4dp" android:layout_marginBottom="20dp" android:clickable="true" android:focusable="true">
        <TextView android:layout_width="match_parent" android:fontFamily="@font/atista" android:layout_height="wrap_content" android:text="Entrar" android:textSize="30dp" android:textColor="#FFFFFF" android:textStyle="bold" android:gravity="center" android:padding="15dp" android:background="#FF7B6B"/>
    </androidx.cardview.widget.CardView>
    <!--  Link para cadastro  -->
    <TextView android:id="@+id/signUpLink" android:alpha="0.7" android:fontFamily="@font/robotoregular" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Quero me cadastrar" android:textSize="14sp" android:textColor="#666666" android:layout_gravity="center" android:clickable="true" android:focusable="true"/>
</LinearLayout>
</androidx.cardview.widget.CardView>
    </RelativeLayout>