<?xml version="1.0" encoding="utf-8"?>

<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/banner2_v2">

    <!-- Overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="60dp"
            android:paddingBottom="32dp"
            android:paddingHorizontal="30dp">

            <!-- Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="30dp"
                android:layout_marginRight="30dp"
                android:alpha="0.8"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp"
                android:background="#E8E8E8">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="30dp"
                    android:background="#E8E8E8">

                    <!-- Título -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginBottom="30dp"
                        android:text="Cadastro"
                        android:textColor="#FF7B6B"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/atista"/>

                    <!-- Nome -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nome completo"
                        android:textSize="14sp"
                        android:textColor="@color/yamamoto_bold"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"
                        android:fontFamily="@font/robotoregular"/>

                    <EditText
                        android:id="@+id/nomeInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Ex: Pedro Silva"
                        android:textSize="14sp"
                        android:textColorHint="#999999"
                        android:background="@android:color/transparent"
                        android:inputType="textPersonName"
                        android:alpha="0.5"
                        android:fontFamily="@font/robotoregular"
                        android:layout_marginBottom="20dp"/>

                    <!-- Email -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="E-mail"
                        android:textSize="14sp"
                        android:textColor="@color/yamamoto_bold"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"
                        android:fontFamily="@font/robotoregular"/>

                    <EditText
                        android:id="@+id/emailCadastroInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Digite seu e-mail"
                        android:textSize="14sp"
                        android:textColorHint="#999999"
                        android:background="@android:color/transparent"
                        android:inputType="textEmailAddress"
                        android:alpha="0.5"
                        android:fontFamily="@font/robotoregular"
                        android:layout_marginBottom="20dp"/>

                    <!-- Senha -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Senha"
                        android:textSize="14sp"
                        android:textColor="@color/yamamoto_bold"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"
                        android:fontFamily="@font/robotoregular"/>

                    <EditText
                        android:id="@+id/senhaCadastroInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Mínimo 6 caracteres"
                        android:textSize="14sp"
                        android:textColorHint="#999999"
                        android:background="@android:color/transparent"
                        android:inputType="textPassword"
                        android:alpha="0.5"
                        android:fontFamily="@font/robotoregular"
                        android:layout_marginBottom="20dp"/>

                    <!-- Confirmar senha -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Confirmar Senha"
                        android:textSize="14sp"
                        android:textColor="@color/yamamoto_bold"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"
                        android:fontFamily="@font/robotoregular"/>

                    <EditText
                        android:id="@+id/confirmarSenhaInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Repita a senha"
                        android:textSize="14sp"
                        android:textColorHint="#999999"
                        android:background="@android:color/transparent"
                        android:inputType="textPassword"
                        android:alpha="0.5"
                        android:fontFamily="@font/robotoregular"
                        android:layout_marginBottom="30dp"/>

                    <!-- Botão -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/btnCadastrar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="25dp"
                        app:cardElevation="4dp"
                        android:layout_marginBottom="20dp"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Criar Conta"
                            android:textSize="22sp"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:padding="15dp"
                            android:background="#FF7B6B"
                            android:fontFamily="@font/atista"/>
                    </androidx.cardview.widget.CardView>

                    <!-- Voltar -->
                    <TextView
                        android:id="@+id/tvVoltar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Já tenho conta · Fazer login"
                        android:textSize="14sp"
                        android:textColor="#666666"
                        android:layout_gravity="center"
                        android:clickable="true"
                        android:focusable="true"
                        android:alpha="0.7"
                        android:fontFamily="@font/robotoregular"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </ScrollView>

</RelativeLayout>