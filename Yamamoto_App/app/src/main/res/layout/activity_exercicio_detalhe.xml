<?xml version="1.0" encoding="utf-8"?>
<!-- Tela de Detalhes do Exercício com ConstraintLayout -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- Cabeçalho colorido -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerDetalhe"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#FF7B6B"
        android:paddingTop="48dp"
        android:paddingBottom="24dp"
        android:paddingHorizontal="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Botão Voltar -->
        <Button
            android:id="@+id/btnVoltar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Voltar"
            android:textColor="#FFFFFF"
            android:background="@android:color/transparent"
            android:textSize="14sp"
            app:layout_constraintTop_toTopOf="parent"
            android:fontFamily="@font/robotoregular"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- ImageView do exercício -->
        <ImageView
            android:id="@+id/ivExercicio"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_marginTop="16dp"
            android:src="@drawable/ic_exercicio_placeholder"
            android:contentDescription="Imagem do exercício"
            android:scaleType="centerInside"
            app:layout_constraintTop_toBottomOf="@id/btnVoltar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Nome do exercício -->
        <TextView
            android:id="@+id/tvDetalheNome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/robotobold"
            app:layout_constraintTop_toBottomOf="@id/ivExercicio"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Categoria -->
        <TextView
            android:id="@+id/tvDetalheCategoria"
            android:layout_width="0dp"
            android:fontFamily="@font/robotobold"
            android:layout_height="wrap_content"
            android:textColor="#FFE0DC"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvDetalheNome"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Conteúdo rolável -->
    <ScrollView
        android:id="@+id/scrollDetalhe"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/headerDetalhe"
        app:layout_constraintBottom_toTopOf="@id/layoutBotoesDetalhe"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Card: Dados numéricos de prescrição -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PRESCRIÇÃO"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#FF7B6B"
                        android:letterSpacing="0.1"
                        android:fontFamily="@font/robotoregular"
                        android:layout_marginBottom="8dp" />

                    <TextView android:id="@+id/tvDetalheFrequencia"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="14sp" android:textColor="#444444"
                        android:drawableStart="@drawable/ic_calendar"
                        android:drawablePadding="8dp" android:layout_marginBottom="6dp" />

                    <TextView android:id="@+id/tvDetalheDuracao"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="14sp" android:textColor="#444444"
                        android:drawableStart="@drawable/ic_time"
                        android:drawablePadding="8dp" android:layout_marginBottom="6dp" />

                    <TextView android:id="@+id/tvDetalheSeries"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="14sp" android:textColor="#444444"
                        android:drawableStart="@drawable/ic_repeat"
                        android:drawablePadding="8dp" android:layout_marginBottom="6dp" />

                    <!-- Dado numérico: carga semanal -->
                    <TextView android:id="@+id/tvDetalheCarga"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="14sp" android:textColor="#FF7B6B"
                        android:textStyle="bold"
                        android:drawablePadding="8dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card: Descrição -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DESCRIÇÃO"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#FF7B6B"
                        android:letterSpacing="0.1"
                        android:fontFamily="@font/robotoregular"
                        android:layout_marginBottom="8dp" />
                    <TextView
                        android:id="@+id/tvDetalheDescricao"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="#555555"
                        android:lineSpacingMultiplier="1.4" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card: Orientações -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="COMO FAZER"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#FF7B6B"
                        android:letterSpacing="0.1"
                        android:fontFamily="@font/robotoregular"
                        android:layout_marginBottom="8dp" />
                    <TextView
                        android:id="@+id/tvDetalheOrientacoes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="#555555"
                        android:lineSpacingMultiplier="1.5" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- Botões fixos na parte inferior -->
    <LinearLayout
        android:id="@+id/layoutBotoesDetalhe"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="#FFFFFF"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">


        <!-- Botão Ver Vídeo — Intent Implícita -->
        <Button
            android:id="@+id/btnVerVideo"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="▶ Ver Vídeo"
            android:textColor="#FF7B6B"
            android:backgroundTint="#FFE0DC"
            android:fontFamily="@font/robotobold" />

        <!-- Botão Registrar Execução — Intent Explícita -->
        <Button
            android:id="@+id/btnRegistrarExecucao"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:background="#FF7B6B"
            android:fontFamily="@font/robotobold"
            android:text="✓ Registrar"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
