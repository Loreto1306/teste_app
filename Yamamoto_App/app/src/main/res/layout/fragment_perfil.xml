<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Cabeçalho com avatar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FF7B6B"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="60dp"
            android:paddingBottom="30dp">

            <!-- Avatar circular com iniciais -->
            <TextView
                android:id="@+id/tvPerfilIniciais"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@drawable/circle_white"
                android:gravity="center"
                android:text="MS"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#FF7B6B" />

            <TextView
                android:id="@+id/tvPerfilNome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nome do Paciente"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginTop="12dp" />

            <TextView
                android:id="@+id/tvPerfilEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="email@exemplo.com"
                android:textColor="#FFE0DC"
                android:textSize="13sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Cards de estatísticas -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:id="@+id/tvEstatisticaDor"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sem registros"
                        android:textSize="13sp"
                        android:textColor="#FF7B6B"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Indicador de Dor"
                        android:textSize="11sp"
                        android:textColor="#AAAAAA" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:id="@+id/tvEstatisticaExec"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 sessão(ões)"
                        android:textSize="13sp"
                        android:textColor="#4CAF50"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sessões Concluídas"
                        android:textSize="11sp"
                        android:textColor="#AAAAAA" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Botões -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <Button
                android:id="@+id/btnNotificacoes"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="🔔 Configurar Notificações"
                android:textColor="#FF7B6B"
                android:backgroundTint="#FFE0DC"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Sair da Conta"
                android:textColor="#FFFFFF"
                android:backgroundTint="#FF7B6B"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Rodapé LGPD -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Seus dados são protegidos conforme a LGPD.\nClínica Maya © 2025"
            android:textSize="11sp"
            android:textColor="#AAAAAA"
            android:gravity="center"
            android:padding="16dp" />

    </LinearLayout>
</ScrollView>
