<?xml version="1.0" encoding="utf-8"?>

<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/banner2_v2">

    <!-- Overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"/>

    <!-- Card -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:layout_marginHorizontal="30dp"
        android:alpha="0.8"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        android:background="#E8E8E8">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="30dp"
            android:background="#E8E8E8">

            <!-- Título -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginBottom="16dp"
                android:fontFamily="@font/atista"
                android:text="Recuperar Senha"
                android:textColor="#FF7B6B"
                android:textSize="28sp"
                android:textStyle="bold"/>

            <!-- Descrição -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/robotoregular"
                android:text="Informe seu e-mail e enviaremos as instruções de redefinição."
                android:textSize="13sp"
                android:textColor="#666666"
                android:gravity="center"
                android:layout_marginBottom="24dp"/>

            <!-- Label E-mail -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/robotoregular"
                android:text="E-mail"
                android:textSize="14sp"
                android:textColor="@color/yamamoto_bold"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <!-- Campo E-mail -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:layout_marginBottom="24dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginRight="10dp"
                    android:alpha="0.5"
                    android:src="@drawable/ic_email"
                    android:contentDescription="Email icon"/>

                <EditText
                    android:id="@+id/emailRecuperacao"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/robotoregular"
                    android:alpha="0.5"
                    android:hint="Digite seu e-mail"
                    android:textSize="14sp"
                    android:textColorHint="#999999"
                    android:background="@android:color/transparent"
                    android:inputType="textEmailAddress"/>
            </LinearLayout>

            <!-- Botão Enviar -->
            <androidx.cardview.widget.CardView
                android:id="@+id/btnEnviarRecuperacao"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="25dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="20dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/atista"
                    android:text="Enviar Instruções"
                    android:textSize="24sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:padding="15dp"
                    android:background="#FF7B6B"/>
            </androidx.cardview.widget.CardView>

            <!-- Voltar -->
            <TextView
                android:id="@+id/tvVoltarLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="@font/robotoregular"
                android:alpha="0.7"
                android:text="Voltar ao Login"
                android:textSize="14sp"
                android:textColor="#666666"
                android:clickable="true"
                android:focusable="true"/>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</RelativeLayout>