<?xml version="1.0" encoding="utf-8"?>
<!-- Item do RecyclerView: Card de exercício -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Número do exercício (círculo colorido) -->
        <TextView
            android:id="@+id/tvNumero"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:fontFamily="@font/robotobold"
            android:textSize="18sp"
            android:background="@drawable/circle_primary"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Nome do exercício -->
        <TextView
            android:id="@+id/tvNomeExercicio"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:fontFamily="@font/robotobold"
            android:textColor="#333333"
            android:layout_marginStart="12dp"
            app:layout_constraintTop_toTopOf="@id/tvNumero"
            app:layout_constraintStart_toEndOf="@id/tvNumero"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Categoria -->
        <TextView
            android:id="@+id/tvCategoria"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="#FF7B6B"
            android:fontFamily="@font/robotobold"
            android:layout_marginStart="12dp"
            android:layout_marginTop="2dp"
            app:layout_constraintTop_toBottomOf="@id/tvNomeExercicio"
            app:layout_constraintStart_toEndOf="@id/tvNumero" />

        <!-- Divider -->
        <View
            android:id="@+id/divider"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:background="#EEEEEE"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/tvNumero"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Linha de dados: Frequência e Duração -->
        <TextView
            android:id="@+id/tvFrequencia"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#666666"
            android:drawablePadding="4dp"
            android:layout_marginTop="10dp"
            android:fontFamily="@font/robotoregular"
            app:layout_constraintTop_toBottomOf="@id/divider"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/tvDuracao" />

        <TextView
            android:id="@+id/tvDuracao"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#666666"
            android:layout_marginTop="10dp"
            android:fontFamily="@font/robotoregular"
            app:layout_constraintTop_toBottomOf="@id/divider"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Séries e Repetições -->
        <TextView
            android:id="@+id/tvSeries"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#555555"
            android:fontFamily="@font/robotoregular"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvFrequencia"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/tvCargaSemanal" />

        <!-- Carga semanal — dado numérico destacado -->
        <TextView
            android:id="@+id/tvCargaSemanal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#FF7B6B"
            android:fontFamily="@font/robotobold"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvDuracao"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>
