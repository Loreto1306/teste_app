<?xml version="1.0" encoding="utf-8"?>
<!-- Tela de Registro de Execução: dados numéricos dor/mobilidade -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- Cabeçalho -->
    <TextView
        android:id="@+id/tvHeaderRegistro"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#FF7B6B"
        android:fontFamily="@font/atista"
        android:text="Registrar Execução"
        android:textColor="#FFFFFF"
        android:textSize="26sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingTop="52dp"
        android:paddingBottom="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/tvHeaderRegistro"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Nome do exercício -->
            <TextView
                android:id="@+id/tvNomeRegistro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/robotoregular"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:layout_marginBottom="20dp" />

            <!-- Card: Check-in de execução -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:gravity="center_vertical">
                    <CheckBox
                        android:id="@+id/checkExecutado"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:buttonTint="#FF7B6B" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Exercício executado hoje"
                        android:textSize="15sp"
                        android:textColor="#333333"
                        android:layout_marginStart="12dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card: Dor (0–10) -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Nível de Dor"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#333333" />
                        <TextView
                            android:id="@+id/tvDorValor"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 – Sem dor"
                            android:textSize="13sp"
                            android:textColor="#FF7B6B"
                            android:textStyle="bold" />
                    </LinearLayout>
                    <!-- Legenda da escala -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="0" android:textSize="11sp"
                            android:textColor="#888" android:gravity="start" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Sem dor ←────────────→ Máxima" android:textSize="10sp" android:textColor="#888" />
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="10" android:textSize="11sp"
                            android:textColor="#888" android:gravity="end" />
                    </LinearLayout>
                    <SeekBar
                        android:id="@+id/seekBarDor"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="10"
                        android:progress="0"
                        android:progressTint="#FF7B6B"
                        android:thumbTint="#FF7B6B" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card: Mobilidade (0–10) -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Mobilidade"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="#333333" />
                        <TextView
                            android:id="@+id/tvMobilidadeValor"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="5 / 10"
                            android:textSize="13sp"
                            android:textColor="#4CAF50"
                            android:textStyle="bold" />
                    </LinearLayout>
                    <SeekBar
                        android:id="@+id/seekBarMobilidade"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:max="10"
                        android:progress="5"
                        android:progressTint="#4CAF50"
                        android:thumbTint="#4CAF50" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card: Séries e Repetições realizadas -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SÉRIES E REPETIÇÕES REALIZADAS"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#FF7B6B"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginEnd="8dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Séries"
                                android:textSize="12sp"
                                android:textColor="#666666"
                                android:layout_marginBottom="4dp" />
                            <EditText
                                android:id="@+id/etSeriesRealizadas"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:inputType="number"
                                android:textSize="16sp"
                                android:gravity="center"
                                android:background="@drawable/input_background" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="8dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Repetições"
                                android:textSize="12sp"
                                android:textColor="#666666"
                                android:layout_marginBottom="4dp" />
                            <EditText
                                android:id="@+id/etRepeticoesRealizadas"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:inputType="number"
                                android:textSize="16sp"
                                android:gravity="center"
                                android:background="@drawable/input_background" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card: Observações -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="OBSERVAÇÕES"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#FF7B6B"
                        android:layout_marginBottom="8dp" />
                    <EditText
                        android:id="@+id/etObservacoes"
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:hint="Como você se sentiu? Alguma dificuldade?"
                        android:inputType="textMultiLine"
                        android:gravity="top"
                        android:textSize="14sp"
                        android:background="@drawable/input_background"
                        android:padding="12dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Botões de ação -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="32dp">

                <Button
                    android:id="@+id/btnCancelarRegistro"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="Cancelar"
                    android:textColor="#FF7B6B"
                    android:backgroundTint="#FFE0DC" />

                <Button
                    android:id="@+id/btnSalvarRegistro"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="Salvar Registro"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#FF7B6B"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
